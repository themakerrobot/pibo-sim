<?xml version="1.0"?>
<robot name="pibo_10dof">

  <material name="white"><color rgba="0.94 0.94 0.95 1"/></material>
  <material name="skyblue"><color rgba="0.30 0.74 0.90 1"/></material>
  <material name="dark"><color rgba="0.20 0.21 0.23 1"/></material>
  <material name="black"><color rgba="0.05 0.05 0.06 1"/></material>
  <material name="grey"><color rgba="0.55 0.55 0.57 1"/></material>
  <material name="silver"><color rgba="0.80 0.81 0.83 1"/></material>

  <link name="base_link">
    <visual>
      <origin xyz="-0.00000 -0.00000 -0.00000" rpy="0 0 0"/>
      <geometry><mesh filename="torso.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="-0.00000 -0.00000 -0.00000" rpy="0 0 0"/>
      <geometry><mesh filename="torso_lcd.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.00000 -0.00000 -0.00000" rpy="0 0 0"/>
      <geometry><mesh filename="torso_sensor.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin xyz="-0.00000 -0.00000 -0.00000" rpy="0 0 0"/>
      <geometry><mesh filename="torso_button.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="-0.00000 -0.00000 -0.00000" rpy="0 0 0"/>
      <geometry><mesh filename="torso_dc.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.00000 -0.00000 -0.00000" rpy="0 0 0"/>
      <geometry><mesh filename="torso_usb.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="silver"/>
    </visual>
  </link>

  <!-- HEAD PAN M4 +-50 -->
  <joint name="head_pan_joint" type="revolute">
    <parent link="base_link"/><child link="head_pan_link"/>
    <origin xyz="0.00000 0.00007 0.23833"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8727" upper="0.8727" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="head_pan_link">
    <visual>
      <origin xyz="-0.00000 -0.00007 -0.23833" rpy="0 0 0"/>
      <geometry><mesh filename="neck_l.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- HEAD TILT M5 +-25 -->
  <joint name="head_tilt_joint" type="revolute">
    <parent link="head_pan_link"/><child link="head_link"/>
    <origin xyz="0.00066 0.00007 0.04793"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.4363" upper="0.4363" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="head_link">
    <visual>
      <origin xyz="-0.00067 -0.00014 -0.28627" rpy="0 0 0"/>
      <geometry><mesh filename="head.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="-0.00067 -0.00014 -0.28627" rpy="0 0 0"/>
      <geometry><mesh filename="head_top.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="skyblue"/>
    </visual>
    <visual>
      <origin xyz="-0.00067 -0.00014 -0.28627" rpy="0 0 0"/>
      <geometry><mesh filename="head_eye.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.00067 -0.00014 -0.28627" rpy="0 0 0"/>
      <geometry><mesh filename="head_glasses.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin xyz="-0.00067 -0.00014 -0.28627" rpy="0 0 0"/>
      <geometry><mesh filename="head_mouth.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- SHOULDER L M8 +-80 -->
  <joint name="shoulder_l_joint" type="revolute">
    <parent link="base_link"/><child link="shoulder_l_link"/>
    <origin xyz="0.06451 0.00014 0.20270"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.3963" upper="1.3963" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="shoulder_l_link">
    <visual>
      <origin xyz="-0.06451 -0.00014 -0.20270" rpy="0 0 0"/>
      <geometry><mesh filename="shoulder_l.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ELBOW L M9 +-30 -->
  <joint name="elbow_l_joint" type="revolute">
    <parent link="shoulder_l_link"/><child link="arm_l_link"/>
    <origin xyz="0.03852 0.00008 -0.02552"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5236" upper="0.5236" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="arm_l_link">
    <visual>
      <origin xyz="-0.10303 -0.00023 -0.17717" rpy="0 0 0"/>
      <geometry><mesh filename="arm_l.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- SHOULDER R M2 +-80 -->
  <joint name="shoulder_r_joint" type="revolute">
    <parent link="base_link"/><child link="shoulder_r_link"/>
    <origin xyz="-0.06446 0.00014 0.20304"/>
    <axis xyz="-1 0 0"/>
    <limit lower="-1.3963" upper="1.3963" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="shoulder_r_link">
    <visual>
      <origin xyz="0.06446 -0.00014 -0.20304" rpy="0 0 0"/>
      <geometry><mesh filename="shoulder_r.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ELBOW R M3 +-30 -->
  <joint name="elbow_r_joint" type="revolute">
    <parent link="shoulder_r_link"/><child link="arm_r_link"/>
    <origin xyz="-0.03849 -0.00069 -0.02580"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5236" upper="0.5236" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="arm_r_link">
    <visual>
      <origin xyz="0.10295 0.00055 -0.17725" rpy="0 0 0"/>
      <geometry><mesh filename="arm_r.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- HIP L M7 +-35 -->
  <joint name="hip_l_joint" type="revolute">
    <parent link="base_link"/><child link="leg_l_link"/>
    <origin xyz="0.03301 0.00024 0.11176"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.6109" upper="0.6109" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="leg_l_link">
    <visual>
      <origin xyz="-0.03301 -0.00024 -0.11176" rpy="0 0 0"/>
      <geometry><mesh filename="leg_l.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ANKLE L M6 +-25 -->
  <joint name="ankle_l_joint" type="revolute">
    <parent link="leg_l_link"/><child link="foot_l_link"/>
    <origin xyz="0.00257 -0.00583 -0.07298"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.4363" upper="0.4363" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="foot_l_link">
    <visual>
      <origin xyz="-0.03558 0.00558 -0.03878" rpy="0 0 0"/>
      <geometry><mesh filename="foot_l.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="-0.03558 0.00558 -0.03878" rpy="0 0 0"/>
      <geometry><mesh filename="shoes_l.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- HIP R M1 +-35 -->
  <joint name="hip_r_joint" type="revolute">
    <parent link="base_link"/><child link="leg_r_link"/>
    <origin xyz="-0.03328 0.00202 0.11180"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-0.6109" upper="0.6109" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="leg_r_link">
    <visual>
      <origin xyz="0.03328 -0.00202 -0.11180" rpy="0 0 0"/>
      <geometry><mesh filename="leg_r.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ANKLE R M0 +-25 -->
  <joint name="ankle_r_joint" type="revolute">
    <parent link="leg_r_link"/><child link="foot_r_link"/>
    <origin xyz="-0.00230 -0.00733 -0.07272"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.4363" upper="0.4363" effort="1.0" velocity="2.0"/>
  </joint>
  <link name="foot_r_link">
    <visual>
      <origin xyz="0.03559 0.00531 -0.03907" rpy="0 0 0"/>
      <geometry><mesh filename="foot_r.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="0.03559 0.00531 -0.03907" rpy="0 0 0"/>
      <geometry><mesh filename="shoes_r.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="black"/>
    </visual>
  </link>

</robot>
